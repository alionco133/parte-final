SELECT 
    p.nome AS pais,
    m.nome_ia AS ia,
    m.versao,
    e.nome AS empresa,
    d.cidade,
    d.uso_principal,
    d.usuarios_milhoes,
    d.status
FROM data_centers d
JOIN paises p ON d.pais_id = p.id
JOIN modelos_ia m ON d.modelo_ia_id = m.id
JOIN empresas e ON m.empresa_id = e.id
ORDER BY p.nome;

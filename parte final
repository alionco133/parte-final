CREATE TABLE empresas (
    id SERIAL PRIMARY KEY,
    nome VARCHAR(100) NOT NULL
);

CREATE TABLE paises (
    id SERIAL PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    codigo_pais CHAR(2),
    continente VARCHAR(50),
    idioma_principal VARCHAR(50),
    clima VARCHAR(50)
);

CREATE TABLE modelos_ia (
    id SERIAL PRIMARY KEY,
    nome_ia VARCHAR(100) NOT NULL,
    versao VARCHAR(50),
    tipo_modelo VARCHAR(50),
    empresa_id INT REFERENCES empresas(id)
);

CREATE TABLE data_centers (
    id SERIAL PRIMARY KEY,
    pais_id INT REFERENCES paises(id),
    modelo_ia_id INT REFERENCES modelos_ia(id),
    cidade VARCHAR(100),
    regiao VARCHAR(100),
    tipo_data_center VARCHAR(50),
    tipo_resfriamento VARCHAR(100),
    fonte_energia VARCHAR(100),
    ano_instalacao INT,
    status VARCHAR(20),
    num_servidores INT,
    usuarios_milhoes NUMERIC,
    interacoes_dia_mi NUMERIC,
    consumo_agua_mi_l NUMERIC,
    custo_anual_mi_usd NUMERIC,
    latencia_media_ms NUMERIC,
    temp_media_c NUMERIC,
    pico_uso VARCHAR(20),
    uso_principal VARCHAR(100),
    crescimento_anual_pct NUMERIC,
    regulamentacao_ambiental VARCHAR(50),
    reuso_agua VARCHAR(10),
    proximidade_agua VARCHAR(20),
    observacao TEXT
);

